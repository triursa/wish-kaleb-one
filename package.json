{
  "name": "wish-kaleb-one",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler pages dev -- npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy ./dist --project-name=wish",
    "db:init": "wrangler d1 execute wish-kaleb-one-db --remote --command=\"$(cat schema.sql)\"",
    "db:local": "wrangler d1 execute wish-kaleb-one-db --local --command=\"$(cat schema.sql)\""
  },
  "dependencies": {
    "hono": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@hono/node-server": "^1.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0"
  }
}